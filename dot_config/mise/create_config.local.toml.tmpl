# Per-machine mise overrides. Seeded once by chezmoi (`create_`), then safe to
# edit freely — chezmoi will NOT overwrite it on subsequent applies.
#
# The dotfiles-managed baseline lives in individual files under:
#   ~/.config/mise/conf.d/*.toml  (symlinked from ~/.dotfiles/dot_config/mise/conf.d/)
#
# See create_config.toml.tmpl for the tool-by-file table.
#
# Examples:
# [tools]
# node = "22"
# python = "3.13"

[tools]
