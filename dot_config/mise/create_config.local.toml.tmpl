# Per-machine mise overrides. Seeded once by chezmoi (`create_`), then safe to
# edit freely — chezmoi will NOT overwrite it on subsequent applies.
# Shared baseline lives in ~/.config/mise/conf.d/fresh.toml (symlinked from the dotfiles repo).
# Local entry point is ~/.config/mise/config.toml (also seeded once, also editable).
#
# Example:
# [tools]
# node = "22"
# python = "3.13"

[tools]
